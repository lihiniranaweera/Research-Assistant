# OpenAI
OPENAI_API_KEY=sk-...

# Tavily (web search) — get a free key at https://tavily.com
TAVILY_API_KEY=tvly-...

# API key that clients must send in the X-API-Key header
API_KEY=change-me-to-a-secret-value

# Optional overrides
LLM_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small
DATA_DIR=data/collections
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
